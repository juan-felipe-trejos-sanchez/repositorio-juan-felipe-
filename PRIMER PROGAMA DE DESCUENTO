//CREAR UN PROGRAMA QUE CALCULE EL DESCUENTO DE UN 25% DE UN SALARIO DEVENGADO POR UN EMPLEADO, CAPTURA SU NOMBRE Y SU SALARIO

PROCESO DESCUETO
ESCRIBIR "PROGRAMA QUE TE DESCUENTA EL 25%"
ESCRIBIR " DIGITE SU NOMBRE "
LEER NOMBRE 
ESCRIBIR "DIGITE SU SALARIO"
LEER SALARIO
PORCENTAJE = SALARIO * 25 / 100 // ESTA LINEA CALCULA EL PORCENTAJE 
SALARIOTOTAL = SALARIO - PORCENTAJE 
SI SALARIOTOTAL > 1000000 ENTONCES 
ESCRIBIR "SU SALARIO ES MUY ALTO"
SINO
ESCRIBIR " SU SALARIO ES MENOR A UN MILLON"
ESCRIBIR "SU NOMBRE ES" , NOMBRE , " SU SALARIO DEVENGADO ES " , SALARIO , " Y CON EL DESCUENTO DEL 25% SU SALARIO QUEDA EN " , SALARIOTOTAL
FINSI
FINPROCESO
